# Get a FREE key at https://console.groq.com/keys
#
# ONE key:
#   GROQ_API_KEYS=gsk_yourkey
#
# MULTIPLE keys for rotation (yours + a friend's, etc.) — separate with commas,
# NO spaces around the commas. When one account hits its daily limit, the app
# automatically switches to the next key.
#   GROQ_API_KEYS=gsk_yourkey,gsk_friendskey,gsk_anotherkey
#
GROQ_API_KEYS=your_groq_api_key_here

# Models (free on Groq). You can change these if Groq updates model names.
GROQ_TEXT_MODEL=llama-3.3-70b-versatile
# Lighter backup model (higher free daily limit) used if the main one runs out of tokens.
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# Voice-message transcription (speech-to-text). Works in every browser.
GROQ_STT_MODEL=whisper-large-v3-turbo
